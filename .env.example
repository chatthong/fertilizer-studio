# Fertilizer Studio runs fully locally — most configuration lives in-app, not in env.
# These are OPTIONAL development overrides. Copy to `.env` if you need them.
# Never put real secrets here; this is a public, free, offline app.

# URL the app pulls the shared fertilizer library from on launch.
# Points at a file (SQLite .db or JSON) published in this public repo's releases/raw.
# Leave unset to use the built-in default.
# SHARED_LIBRARY_URL=

# Override the local data directory (SQLite DB + cache).
# Defaults to the OS app-data dir when unset.
# APP_DATA_DIR=
